# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control

# Solana RPC
HELIUS_API_KEY=your_helius_api_key_here
RPC_ENDPOINT=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY
DEXSCREENER_API=https://api.dexscreener.com/latest/dex
BIRDEYE_API_KEY=your_birdeye_api_key_here

# Social Sentiment (optional)
TWITTER_API_KEY=your_twitter_api_key
TWITTER_API_SECRET=your_twitter_api_secret
TWITTER_BEARER_TOKEN=your_bearer_token

# Solana Wallet (KEEP SECURE)
# Store keypair JSON path or base58 private key
SOLANA_KEYPAIR_PATH=/path/to/keypair.json

# Jupiter (for swaps)
JUPITER_API=https://quote-api.jup.ag/v6

# Notifications
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# Bot Parameters
MIN_LIQUIDITY_USD=5000
MAX_AGE_MINUTES=60
MAX_HOLDER_CONCENTRATION=0.30
MIN_RENOUNCED_CHECKS=true
PROFIT_TARGET_PERCENT=100
STOP_LOSS_PERCENT=10
RISK_PERCENT=5
WALLET_BALANCE_SOL=1.0
